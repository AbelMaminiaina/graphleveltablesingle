@model GraphLevel1.Web.Models.SearchViewModel
@{
    ViewData["Title"] = "Recherche";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Recherche de Lineage</h4>
            </div>
            <div class="card-body">
                <form asp-action="Search" method="post">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Input 1</label>
                            <input type="text"
                                   asp-for="Input1"
                                   class="form-control"
                                   placeholder="Ex: DATA_1_O1"
                                   autofocus />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Input 2</label>
                            <input type="text"
                                   asp-for="Input2"
                                   class="form-control"
                                   placeholder="Ex: DATA_2_O1" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Input 3</label>
                            <input type="text"
                                   asp-for="Input3"
                                   class="form-control"
                                   placeholder="Ex: DATA_3_O1" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Input 4</label>
                            <input type="text"
                                   asp-for="Input4"
                                   class="form-control"
                                   placeholder="Ex: DATA_4_O1" />
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12 text-center">
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                Rechercher
                            </button>
                            <a href="/" class="btn btn-outline-secondary btn-lg px-4 ms-2">
                                Effacer
                            </a>
                        </div>
                    </div>
                    @if (!ViewContext.ModelState.IsValid)
                    {
                        <div class="row mt-3">
                            <div class="col-12">
                                <div asp-validation-summary="All" class="alert alert-danger"></div>
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.HasSearched && Model.Results.Any())
{
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0">Resultats (@Model.Results.Count transformations trouvees)</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Transformation</th>
                                <th>Proprietaire</th>
                                <th>Type</th>
                                <th class="text-center">Predecesseurs</th>
                                <th class="text-center">Successeurs</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Results)
                            {
                                <tr>
                                    <td><strong>@item.Transformation</strong></td>
                                    <td>@(item.Proprietaire ?? "-")</td>
                                    <td>
                                        <span class="badge bg-secondary">Type @item.IdType</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-danger">@item.PredecessorCount</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-success">@item.SuccessorCount</span>
                                    </td>
                                    <td class="text-center">
                                        <a href="/Graph/Details?transformation=@System.Net.WebUtility.UrlEncode(item.Transformation)" class="btn btn-sm btn-outline-primary">
                                            Voir Graphe
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else if (Model.HasSearched)
{
    <div class="alert alert-info mt-4">
        Aucun resultat trouve pour les criteres specifies.
    </div>
}

<div class="row mt-4">
    <div class="col-12">
        <div class="card bg-light">
            <div class="card-body">
                <h6>Exemples de recherche:</h6>
                <ul class="mb-0">
                    <li><code>Input1: DATA_1</code> - Recherche les donnees contenant "DATA_1"</li>
                    <li><code>Input1: DATA_5_O1, Input2: DATA_6_O2</code> - Recherche avec plusieurs criteres</li>
                    <li><code>Input1: O2</code> - Recherche tous les outputs de type O2</li>
                </ul>
            </div>
        </div>
    </div>
</div>
